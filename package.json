{
  "name": "axiom-forge",
  "version": "1.0.0",
  "description": "Open-source local agent for the idea-to-app pipeline",
  "main": "main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest"
  },
  "keywords": [
    "electron",
    "react",
    "ollama",
    "ai",
    "deployment",
    "open-source"
  ],
  "author": "Axiom Forge Community",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "vercel": "^39.0.0",
    "zustand": "^5.0.0",
    "node-fetch": "^3.3.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.axiomforge.app",
    "productName": "Axiom Forge",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    },
    "protocols": [
      {
        "name": "Axiom Forge Protocol",
        "schemes": ["axiom"]
      }
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
